# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Build output ───────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo

# ── Dependencies ───────────────────────────────────────────────
node_modules/

# ── Secrets & local env ────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── User-uploaded files ────────────────────────────────────────
uploads/
artifacts/api-server/uploads/

# ── Replit-only (do not push to GitHub) ────────────────────────
.cache/
.local/
.agents/
.replit
.replitignore
.upm/
attached_assets/
replit.md

# ── Vercel ─────────────────────────────────────────────────────
.vercel/

# ── Logs ───────────────────────────────────────────────────────
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── IDE / OS ───────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.DS_Store
Thumbs.db

# ── Misc ───────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/typings
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
