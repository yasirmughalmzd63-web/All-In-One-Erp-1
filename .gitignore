# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Build output ───────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# IMPORTANT: keep the pre-built backend bundle in the repo so Hostinger
# can run it directly without an `npm install` / build step.
!deploy-package/api-server/dist/
!deploy-package/api-server/dist/**

# ── Dependencies ───────────────────────────────────────────────
node_modules/

# ── Secrets & local env ────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Android build output (mobile) ──────────────────────────────
artifacts/mobile/android/build/
artifacts/mobile/android/app/build/
artifacts/mobile/android/.gradle/
artifacts/mobile/ios/build/
*.apk
*.aab
*.keystore

# ── Replit-only (do not push to GitHub) ────────────────────────
.cache/
.local/
.agents/
.replit
.replitignore
.upm/
attached_assets/
replit.md

# ── Logs ───────────────────────────────────────────────────────
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── IDE / OS ───────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.DS_Store
Thumbs.db

# ── Misc ───────────────────────────────────────────────────────
/.sass-cache
/connect.lock
/coverage
/typings
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
