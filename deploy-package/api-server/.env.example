# ─────────────────────────────────────────────────────────────────────────────
# Coins Sale ERP — API Server environment
# Copy this file to `.env` and fill in real values for your Hostinger setup.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
# On Hostinger, create a PostgreSQL DB from the control panel and paste the URL.
DATABASE_URL=postgres://user:password@localhost:5432/coins_sale

# HTTP port the Node process should listen on. Hostinger usually injects PORT
# automatically — keep this only if running behind a manual reverse proxy.
PORT=8080

# Node environment. ALWAYS set to "production" on Hostinger.
NODE_ENV=production

# NOTE: The server mounts all routes under the hardcoded prefix `/api`.
# Your reverse proxy / domain just needs to forward traffic to this Node
# process — the server itself takes care of the `/api` path. The mobile app
# calls `https://<your-domain>/api/<route>`.

# Session/JWT secret. Use any long random string (at least 32 characters).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# ─────────── Image / payment-proof uploads (local filesystem) ───────────
# Product images and payment-proof screenshots are stored on the local
# filesystem and served at https://<your-domain>/api/uploads/<key>. No cloud
# SDK is needed — works on any Node host.

# Where uploaded files are stored on disk. Defaults to ./uploads next to the
# server. On Hostinger, point this at a *persistent* folder OUTSIDE the app
# directory so files survive redeploys, e.g.:
#   UPLOADS_DIR=/home/<your-hostinger-user>/coins-sale-uploads
UPLOADS_DIR=./uploads

# The public HTTPS base URL for your API (used to build absolute URLs returned
# by the upload endpoints, e.g. "https://api.example.com/api/uploads/..."). If
# blank, the server derives it from the incoming request — that works fine
# when Hostinger sets X-Forwarded-Proto/Host correctly (it does), but setting
# this explicitly is safer.
# PUBLIC_BASE_URL=https://api.your-domain.com
