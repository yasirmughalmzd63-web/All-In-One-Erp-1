# ─── Required ─────────────────────────────────────────────────────────
# Postgres connection string. On Vercel, add this in Project → Settings → Environment Variables.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string (≥ 32 chars) used to sign sessions / tokens.
SESSION_SECRET=replace-me-with-a-long-random-string

# ─── Optional ─────────────────────────────────────────────────────────
# Used for sending the runtime mode to libraries (Express logging, etc.).
NODE_ENV=production

# Public base URL of the deployed API, e.g. https://your-app.vercel.app
# If blank, the server derives it from the incoming request — fine on Vercel.
PUBLIC_BASE_URL=

# Where uploaded images are written. On Vercel this is automatically /tmp/uploads
# (writable but EPHEMERAL — files vanish between invocations). For real
# persistence, swap the upload route for Vercel Blob / S3 / R2.
# UPLOADS_DIR=/var/data/uploads
